pipeline {
    agent {
        node {
            label "docker-esa"
        }
    }

    tools {nodejs "nodejs 18.16.0"}

    stages {
        stage('CHECKOUT SCM') {
            steps {
                git branch: 'main', url: 'https://github.com/esaanugraha/simple-apps.git'
            }
        }

        stage('BUILD MODULE') {
            steps {
                sh '''cd app
                npm install'''
            }
        }

        stage('UNIT TEST') {
            steps {
                sh '''cd app
                npm test'''
            }
        }

        stage('CODE REVIEW') {
            steps {
                sh '''cd app
                sonar-scanner \
                -Dsonar.projectKey=simple-apps \
                -Dsonar.sources=. \
                -Dsonar.host.url=http://172.23.11.16:9000 \
                -Dsonar.login=sqp_2956f2dcd98ae55c316953a0bcad4ece6579d57c'''
            }
        }

        stage('BUILD COMPOSE-DOCKER') {
            steps {
                sh '''
                docker compose build
                docker compose up -d'''
            }
        }

        stage('BUILD COMPOSE-DOCKER') {
            steps {
                sh '''
                docker push esanugraha/simple-esa:latest'''
            }
        }
    }
}